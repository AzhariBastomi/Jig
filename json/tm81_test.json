{
  "connection": "ch340",

  "_doc_commissioning": "Nilai commissioning per batch — edit sebelum mulai produksi. '@key' = ambil dari context (UI field).",
  "commissioning": {
    "set_id": { "device_id": "@device_id" },
    "lora_set_join_mode": { "_doc": "0=None, 1=ABP, 2=OTAA", "join_mode": 2 },
    "lora_set_dev_class": { "_doc": "0=Class A, 1=Class B, 2=Class C", "dev_class": 0 },
    "lora_set_dev_eui":   { "_doc": "8 bytes hex, unik per device", "dev_eui": "0080E10101010104" },
    "lora_set_join_eui":  { "_doc": "8 bytes hex, sama per batch", "join_eui": "0000000000000001" },
    "lora_set_app_key":   { "_doc": "16 bytes hex (OTAA)", "app_key": "8833E75406D203F48D1F6D2CCC2815D8" },
    "lora_set_nw_key":    { "_doc": "16 bytes hex (ABP NwkSKey)", "nw_key": "00000000000000000000000000000001" },
    "lora_set_dev_addr":  { "_doc": "integer desimal, unik per device (ABP)", "dev_addr": 1 },
    "lora_set_config":    { "_doc": "tx_power: 0-5, data_rate: 0-5, rx1_delay: detik", "tx_power": 0, "data_rate": 2, "rx1_delay": 2 },
    "user_set_config": {
      "_doc": "activation:1=ACTIVATED, counter_res:0=1L/1=10L/2=100L, submit_id:0=30mnt/1=1jam",
      "activation": 1, "initial_counter": 0, "counter_res": 1,
      "alarm": 0, "submit_id": 0, "timezone": 7, "msg_type": 1
    }
  },

  "tests": [
    { "name": "ping",               "label": "Ping MCU",               "command_class": "commands.tm81.ping.Ping",                                      "description": "Dihandle otomatis oleh KeepaliveManager (bukan test task)", "disabled": true },
    { "name": "get_version",        "label": "Get Firmware Version",   "command_class": "commands.tm81.user_get_version.UserGetVersion",                 "description": "Baca versi App dan Bootloader" },
    { "name": "get_id",             "label": "Get Device ID",          "command_class": "commands.tm81.dev_get_id.DevGetId",                             "description": "Baca Device ID dari memori" },
    { "name": "set_id",             "label": "Set Device ID",          "command_class": "commands.tm81.dev_set_id.DevSetId",                             "description": "Tulis Device ID dari field UI",                      "disabled": true },
    { "name": "rtc_set",            "label": "Set RTC",                "command_class": "commands.tm81.rtc_set_time.RtcSetTime",                         "description": "Sinkronisasi RTC device ke waktu PC" },
    { "name": "rtc_get",            "label": "Get RTC Time",           "command_class": "commands.tm81.rtc_get_time.RtcGetTime",                         "description": "Baca waktu RTC dari device" },
    { "name": "user_get_config",    "label": "Get User Config",        "command_class": "commands.tm81.user_get_config.UserGetConfig",                   "description": "Baca konfigurasi user",                              "disabled": false },
    { "name": "user_set_config",    "label": "Set User Config",        "command_class": "commands.tm81.user_set_config.UserSetConfig",                   "description": "Set konfigurasi user" },
    { "name": "user_synch_config",  "label": "Sync User Config",       "command_class": "commands.tm81.user_synch_config.UserSynchConfig",               "description": "Sinkronisasi user config ke device" },
    { "name": "user_reset_config",  "label": "Reset User Config",      "command_class": "commands.tm81.user_reset_config.UserResetConfig",               "description": "Reset konfigurasi user ke default" },
    { "name": "sensor_do_get_config","label": "Sensor Trigger Config", "command_class": "commands.tm81.sensor_do_get_config.SensorDoGetConfig",          "description": "Trigger satu siklus pembacaan sensor" },
    { "name": "sensor_data",        "label": "Get Sensor Data",        "command_class": "commands.tm81.sensor_get_data.SensorGetData",                   "description": "Baca data mentah sensor" },
    { "name": "sensor_calibration", "label": "Sensor Calibration",     "command_class": "commands.tm81.sensor_calibration.SensorCalibration",            "description": "Kalibrasi sensor", "no_retry": true, "disabled":true},
    { "name": "lora_get_config",    "label": "Get LoRa Config",        "command_class": "commands.tm81.lora_get_config.LoraGetConfig",                   "description": "Baca konfigurasi LoRaWAN",                           "disabled": true },
    { "name": "lora_set_dev_eui",   "label": "Set DevEUI",             "command_class": "commands.tm81.lora_set_dev_eui.LoraSetDevEui",                  "description": "Set DevEUI device (8 bytes)",                        "disabled": true },
    { "name": "lora_set_join_eui",  "label": "Set JoinEUI",            "command_class": "commands.tm81.lora_set_join_eui.LoraSetJoinEui",                "description": "Set JoinEUI / AppEUI (8 bytes)",                     "disabled": true },
    { "name": "lora_set_app_key",   "label": "Set AppKey",             "command_class": "commands.tm81.lora_set_app_key.LoraSetAppKey",                  "description": "Set AppKey LoRaWAN (16 bytes)",                      "disabled": true },
    { "name": "lora_set_nw_key",    "label": "Set NwKey",              "command_class": "commands.tm81.lora_set_nw_key.LoraSetNwKey",                    "description": "Set NwKey LoRaWAN (16 bytes)",                       "disabled": true },
    { "name": "lora_set_dev_addr",  "label": "Set DevAddr",            "command_class": "commands.tm81.lora_set_dev_addr.LoraSetDevAddr",                "description": "Set DevAddr ABP (4 bytes)",                          "disabled": true },
    { "name": "lora_set_join_mode", "label": "Set Join Mode",          "command_class": "commands.tm81.lora_set_join_mode.LoraSetJoinMode",              "description": "Set LoRa join mode (0=None,1=ABP,2=OTAA)",           "disabled": true },
    { "name": "lora_set_dev_class", "label": "Set Device Class",       "command_class": "commands.tm81.lora_set_dev_class.LoraSetDevClass",              "description": "Set LoRa device class (0=A,1=B,2=C)",                "disabled": true },
    { "name": "lora_set_config",    "label": "Set LoRa Config",        "command_class": "commands.tm81.lora_set_config.LoraSetConfig",                   "description": "Set LoRa TX power, data rate, RX1 delay",            "disabled": true },
    { "name": "lora_force_send",    "label": "LoRa Force Send",        "command_class": "commands.tm81.lora_force_send.LoraForceSend",                   "description": "Paksa device kirim uplink LoRaWAN sekarang",          "disabled": true },
    { "name": "lora_last_submit",   "label": "Get Last Submit Time",   "command_class": "commands.tm81.lora_get_last_submit_time.LoraGetLastSubmitTime", "description": "Baca waktu terakhir device mengirim uplink",          "disabled": true },
    { "name": "dev_info",           "label": "Get Device Info",        "command_class": "commands.tm81.dev_get_info.DevGetInfo",                         "description": "Baca info device: baterai, sensor, LoRa status",     "disabled": true },
    { "name": "backup_read_usage",  "label": "Backup Read Usage",      "command_class": "commands.tm81.backup_read_usage.BackupReadUsage",               "description": "Baca usage history harian/bulanan dari device",       "disabled": true },
    { "name": "backup_write_usage", "label": "Backup Write Usage",     "command_class": "commands.tm81.backup_write_usage.BackupWriteUsage",             "description": "Tulis usage history ke device",                      "disabled": true },
    { "name": "mock_activation",    "label": "Mock Activation",        "command_class": "commands.tm81.mock_activation.MockActivation",                  "description": "Sync RTC + set config + poll join/uplink (max 120s)","disabled": true },
    { "name": "irda_disable",       "label": "IrDA Disable",           "command_class": "commands.tm81.irda_disable.IrdaDisable",                        "description": "Nonaktifkan IrDA pada device",                       "disabled": true },
    { "name": "standby_mode",       "label": "Enter Standby Mode",     "command_class": "commands.tm81.standby_mode.StandbyMode",                        "description": "Masukkan device ke mode standby",                    "disabled": true },
    { "name": "app_goto_bl",        "label": "App to Bootloader",      "command_class": "commands.tm81.app_goto_bl.AppGotoBL",                           "description": "Reboot device ke mode Bootloader",                   "disabled": true },
    { "name": "bl_goto_app",        "label": "Bootloader to App",      "command_class": "commands.tm81.bl_goto_app.BLGotoApp",                           "description": "Dari Bootloader: lompat ke App",                     "disabled": true },
    { "name": "wdt_test",           "label": "WDT Test",               "command_class": "commands.tm81.wdt_test.WdtTest",                                "description": "Test Watchdog Timer (device akan reset)",           "disabled": true }
  ]
}
