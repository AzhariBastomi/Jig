{
  "_doc": "Parameter commissioning per batch produksi. Edit sesuai kebutuhan sebelum mulai test.",

  "set_id": {
    "_doc": "Device ID diambil dari field UI (Device ID / Serial No.)",
    "device_id": "@device_id"
  },

  "lora_set_join_mode": {
    "_doc": "0=None, 1=ABP, 2=OTAA",
    "join_mode": 2
  },

  "lora_set_dev_class": {
    "_doc": "0=Class A, 1=Class B, 2=Class C",
    "dev_class": 0
  },

  "lora_set_dev_eui": {
    "_doc": "8 bytes hex, unik per device. Kosongkan untuk pakai default class.",
    "dev_eui": "0080E10101010104"
  },

  "lora_set_join_eui": {
    "_doc": "8 bytes hex, sama per batch",
    "join_eui": "0000000000000001"
  },

  "lora_set_app_key": {
    "_doc": "16 bytes hex, sama per batch (OTAA)",
    "app_key": "8833E75406D203F48D1F6D2CCC2815D8"
  },

  "lora_set_nw_key": {
    "_doc": "16 bytes hex, sama per batch (ABP NwkSKey)",
    "nw_key": "00000000000000000000000000000001"
  },

  "lora_set_dev_addr": {
    "_doc": "4-byte integer (desimal), unik per device untuk ABP",
    "dev_addr": 1
  },

  "lora_set_config": {
    "_doc": "tx_power: 0-5, data_rate: 0-5 (DR2=SF10), rx1_delay: detik",
    "tx_power":  0,
    "data_rate": 2,
    "rx1_delay": 2
  },

  "user_set_config": {
    "_doc": "activation: 1=ACTIVATED. counter_res: 0=1L,1=10L,2=100L. submit_id: 0=30mnt,1=1jam,...",
    "activation":      1,
    "initial_counter": 0,
    "counter_res":     1,
    "alarm":           0,
    "submit_id":       0,
    "timezone":        7,
    "msg_type":        1
  },

  "ota": {
    "_doc": "Konfigurasi OTA TM81 — fixed per hardware, tidak perlu diubah.",
    "connection":    "ch340",
    "chunk_size":    512,
    "fill_with_ff":  false,
    "bl_boot_wait_s": 1.5
  }
}
